# Copy this file to .env and fill in your real values. Do not commit .env.
# Required for the background monitor (run_monitor.bat / Task Scheduler)

TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

# Same Schwab API credentials you use in the Streamlit app (for token refresh)
SCHWAB_CLIENT_ID=REPLACE_WITH_SCHWAB_APP_KEY
SCHWAB_CLIENT_SECRET=REPLACE_WITH_SCHWAB_SECRET

# Optional: if you use Supabase for saved trades
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# Optional: change check interval (default 5 minutes)
# INTERVAL_MINUTES=5
